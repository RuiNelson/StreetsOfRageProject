#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_DIR="${0:A:h}"
META_ROOT="${SCRIPT_DIR:h}"
SOR_ROOT="$META_ROOT/StreetsOfRageRecompilation"
BIN="$SOR_ROOT/build/sor"
ROM="${SOR_ROM:-$SOR_ROOT/rom/SOR.bin}"

if (( $# )) && [[ "$1" != -* ]]; then
    ROM="$1"
    shift
fi
ROM="${ROM:A}"

if [[ ! -x "$BIN" ]]; then
    print -u2 "Executable not found: $BIN"
    print -u2 "Run scripts/build or scripts/generate_cpp_and_build first."
    exit 1
fi
if [[ ! -f "$ROM" ]]; then
    print -u2 "ROM not found: $ROM"
    exit 1
fi

exec "$BIN" --rom "$ROM" "$@"
